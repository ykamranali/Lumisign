# LumiSign Enterprise — Environment Configuration
# Copy this file to `.env` and adjust values for your deployment.
# All secrets below are EXAMPLES — generate your own for production.

# ---- Server ----
NODE_ENV=development
PORT=4000
# Public URL the server is reachable at (used by Swagger & player config)
SERVER_PUBLIC_URL=http://localhost:4000

# ---- Database (PostgreSQL) ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=lumisign
DB_USER=lumisign
DB_PASSWORD=change_me_strong_password
# When running server locally (not in docker) use DB_HOST=localhost

# ---- Redis (caching, pub/sub) ----
REDIS_URL=redis://redis:6379
# Set to "false" to run without Redis (features degrade gracefully)
REDIS_ENABLED=true

# ---- JWT / Security ----
JWT_SECRET=super_secret_jwt_key_change_me
JWT_EXPIRES_IN=12h
BCRYPT_ROUNDS=12
SESSION_SECRET=session_secret_change_me

# ---- Media Storage ----
# Storage backend: "local" or "minio"
STORAGE_BACKEND=local
MEDIA_ROOT=./storage/media
THUMBS_ROOT=./storage/thumbs
# MinIO (only used when STORAGE_BACKEND=minio)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lumisign

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000

# ---- Optional Cloud Sync ----
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_URL=
CLOUD_SYNC_TOKEN=

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# ---- Initial Admin (used by seed script) ----
SEED_ADMIN_EMAIL=admin@lumisign.io
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Super Admin
